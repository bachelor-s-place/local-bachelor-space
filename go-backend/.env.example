# =============================================================================
# BachelorsSpace — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# Server
PORT=8080
ENV=development                 # development | production

# CORS — comma-separated list of allowed browser origins. Never use "*" in production.
# When unset: defaults to http://localhost:3000 in development, and to "deny all
# cross-origin" in production (set this explicitly before going live).
# CORS_ALLOWED_ORIGINS=https://app.bachelorsspace.in

# Set to true ONLY when running behind a trusted reverse proxy / load balancer that
# sets X-Forwarded-For. When false (default), the rate limiter keys on the raw TCP
# peer IP so clients cannot spoof headers to bypass it.
TRUST_PROXY=false

# Database (PostgreSQL 16+ with PostGIS and pgvector)
# Using 127.0.0.1:5435 for the Dockerized DB (if using provided docker-compose)
DATABASE_URL=postgres://postgres:root@127.0.0.1:5435/bachelors_space?sslmode=disable

# JWT (HS256)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# AES-256 Encryption for PII fields (phone, Aadhaar, PAN)
# Must be exactly 64 hex characters (= 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Google Maps API (for geocoding on property creation)
# GOOGLE_MAPS_API_KEY=

# OpenAI API (for async personality embedding generation)
# OPENAI_API_KEY=

# Embedding Configuration (ollama | openai)
EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=mxbai-embed-large

# Razorpay (wired in Module 8 — leave blank for now)
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Email / SMTP (wired in Module 10 — leave blank for now)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
EMAIL_FROM=noreply@bachelors_space.in
